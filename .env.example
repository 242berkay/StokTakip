# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Use "sqlite" for local development, or "mssql" for Microsoft SQL Server.
DB_ENGINE=sqlite

# Required when DB_ENGINE=mssql
DB_NAME=StokTakip
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd
DB_HOST=localhost
DB_PORT=1433
DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server
DB_EXTRA_PARAMS=TrustServerCertificate=yes
